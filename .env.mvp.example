# NetSuite Demo Helper MVP local profile.
# Copy this to .env.mvp if you want local overrides.

APP_PROFILE=mvp
APP_ENV=development
PORT=4173

# Optional cloud narrator support.
ELEVENLABS_API_KEY=
ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# Optional short-term APEX Shared Local Pilot.
# This is for controlled internal testing only. It lets the APEX cloud UI call
# a secure tunnel/proxy that routes back to this local MVP/Codex bridge.
NSDH_PILOT_MODE=false
NSDH_REQUIRE_PILOT_SECRET=false
NSDH_PILOT_SHARED_SECRET=
NSDH_PILOT_RATE_LIMIT_MAX=120
NSDH_PILOT_RATE_LIMIT_WINDOW_MS=60000

# Use these only while building the APEX package for pilot mode.
NSDH_APEX_RUNTIME_MODE=user-local
NSDH_PILOT_API_BASE_URL=
NSDH_PILOT_HOST_LABEL=Wiljan's Desktop 2 Codex bridge

# Recommended lightweight colleague mode for APEX builds.
# In this mode users download a small helper from the app, run it locally,
# keep Codex open, and the APEX page connects to http://127.0.0.1:4173.
# NSDH_APEX_RUNTIME_MODE=local-helper
NSDH_LOCAL_HELPER_HOST_LABEL=Current user's Local Helper
